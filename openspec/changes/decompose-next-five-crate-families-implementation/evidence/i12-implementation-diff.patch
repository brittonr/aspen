+            mutation_bit in 0u8..8,
+        ) {
+            let share = Share { x, y };
+            let original_digest = share_digest(&share);
+            let mut corrupted = share.clone();
+            corrupted.y[mutation_index] ^= 1u8 << mutation_bit;
+            prop_assert_ne!(share_digest(&corrupted), original_digest);
